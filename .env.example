# Server Configuration
PORT=5000
NODE_ENV=development # Set to production on Vercel

# Gemini AI Configuration
# Get your key at: https://aistudio.google.com/app/apikey
AI_INTEGRATIONS_GEMINI_API_KEY=your_gemini_api_key_here

# Database Configuration (Turso/libSQL)
# Local development uses file:chat.db
# For production (Vercel), create a Turso database: https://turso.tech/
DATABASE_URL=file:chat.db
DATABASE_AUTH_TOKEN=your_turso_auth_token_here
